root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{c,h}]
indent_size = 4

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.{bat,cmd}]
end_of_line = crlf
